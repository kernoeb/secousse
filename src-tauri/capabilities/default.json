{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*.ttvnw.net/*" },
        { "url": "https://*.twitch.tv/*" },
        { "url": "https://*.live-video.net/*" },
        { "url": "https://*.cloudfront.net/*" },
        { "url": "https://*.jtvnw.net/*" },
        { "url": "https://*.akamaized.net/*" }
      ]
    },
    "store:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "log:default"
  ]
}
